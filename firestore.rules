rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Shape + bounds validation for the profile object to reject malformed or
    // oversized writes (defence-in-depth against a tampered client).
    function validProfile(p) {
      return p.uid == request.auth.uid
        && p.displayName is string && p.displayName.size() > 0 && p.displayName.size() <= 80
        && p.email is string && p.email.size() <= 120
        && p.city is string && p.city.size() <= 80
        && p.state is string && p.state.size() <= 60
        && p.householdSize is number && p.householdSize >= 1 && p.householdSize <= 50
        && p.onboarded is bool;
    }

    match /users/{userId} {
      allow read, delete: if isOwner(userId);

      // Only the owner may write, and any profile included must be well-formed.
      allow create, update: if isOwner(userId)
        && (!('profile' in request.resource.data) || validProfile(request.resource.data.profile));

      // Any future per-user subcollections remain strictly owner-scoped.
      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Community forum: shared among authenticated members.
    match /posts/{postId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000
        && request.resource.data.category is string
        && request.resource.data.co2SavedKg is number
        && request.resource.data.co2SavedKg >= 0
        && request.resource.data.co2SavedKg <= 100000
        && request.resource.data.likedBy is list;

      // Members may only toggle likes (no other field may change); authors may
      // delete their own posts.
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy']);
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    // Everything else is denied by default (no implicit public access).
  }
}
