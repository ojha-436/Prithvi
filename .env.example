# ── Firebase (project: supplypulse-c27c0) ───────────────────────────────────
# Get these from Firebase Console → Project settings → Your apps → Web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=supplypulse-c27c0.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=supplypulse-c27c0
VITE_FIREBASE_STORAGE_BUCKET=supplypulse-c27c0.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Gemini (optional) ────────────────────────────────────────────────────────
# RECOMMENDED (secure): deploy functions/ and set the key as a server secret:
#   firebase functions:secrets:set GEMINI_API_KEY
# then enable the server path here (no key in the browser):
VITE_GEMINI_VIA_FUNCTIONS=false
#
# DEV ONLY (exposes the key in the client bundle — do not use in production):
# get a key from https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-1.5-flash
#
# If both are blank, Prithvi uses its built-in deterministic recommendation engine.

# ── App Check (optional, abuse protection) ───────────────────────────────────
# reCAPTCHA v3 site key from Firebase Console → App Check.
VITE_RECAPTCHA_SITE_KEY=

# ── Google sign-in ───────────────────────────────────────────────────────────
# Email/Password works out of the box. To show the "Continue with Google" button,
# enable Google in Firebase Console → Authentication → Sign-in method, then set:
VITE_ENABLE_GOOGLE=false
